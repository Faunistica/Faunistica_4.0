BOT_TOKEN=your_telegram_bot_token # Токен вашего чат-бота в Telegram
BOT_PROXY= # Опционально: socks5://user:pass@host:port или http://host:port
ADMIN_CHAT_ID=-1 # ID телеграм-чата, в котором находится администрация тех.поддержки

 # Опционально: ваш id в телеграм, используется скриптом init для создания тестового пользователя
DEV_TG_ID=

# Данные необходимые для базы данных PostgreSQL
DB_NAME=faunistica
DB_HOST=localhost
DB_PORT=5432
DB_USER=faunistica
DB_PASSWORD=faunistica

JWT_SECRET=dev_secret_change_in_production_min_32_chars
ACCESS_TOKEN_EXPIRE=30
REFRESH_TOKEN_EXPIRE=30

ENCRYPT_SECRET=your_encrypt_secret

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Логирование
LOG_LEVEL=WARNING # DEBUG, INFO, WARNING, ERROR, CRITICAL

# База данных
DB_ECHO=false # Логировать SQL-запросы: true/false
